---
const paths = [
  {
    label: "Licensee",
    title: "License BrazLatch",
    body: "Acquire exclusive rights in your market.",
    cta: { href: "/partner#license", label: "Apply for a license" },
  },
  {
    label: "Distributor",
    title: "Become a Distributor",
    body: "Sell BrazLatch in your region.",
    cta: { href: "/partner#distribute", label: "Apply to distribute" },
  },
  {
    label: "Buyer",
    title: "Find BrazLatch",
    body: "Available across the US through National Hardware, Amazon, and Lowe's.",
    cta: { href: "/buy", label: "See US retailers" },
  },
];
---
<section class="section section-dark">
  <div class="container-page">
    <header class="max-w-2xl">
      <p class="kicker">Three paths</p>
      <h2 class="h2-section mt-3">Pick your way in.</h2>
      <p class="lede mt-4">Whichever role fits, the next step is one click away.</p>
    </header>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {paths.map((p) => (
        <a
          href={p.cta.href}
          class="group rounded-2xl border border-white/10 bg-brand-black/60 p-8 transition hover:border-brand-green/60"
        >
          <p class="kicker">{p.label}</p>
          <h3 class="mt-3 text-2xl font-bold">{p.title}</h3>
          <p class="mt-3 text-brand-white/70 text-sm leading-relaxed">{p.body}</p>
          <p class="mt-6 text-brand-green text-sm font-semibold inline-flex items-center gap-2">
            {p.cta.label}
            <span aria-hidden="true">&rarr;</span>
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
