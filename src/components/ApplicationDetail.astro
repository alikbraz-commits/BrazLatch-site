---
import { Image } from "astro:assets";
import LineArtIcon from "./LineArtIcon.astro";

type IconName =
  | "stalls"
  | "fences"
  | "trailers"
  | "backyards"
  | "warehouse"
  | "farms";

interface Props {
  iconName: IconName;
  code: string;
  label: string;
  headline: string;
  paragraphs: string[];
  specs: Array<[string, string]>;
  callout: string;
  flip?: boolean;
  photoSrc?: ImageMetadata;
  photoAlt?: string;
}

const {
  iconName,
  code,
  label,
  headline,
  paragraphs,
  specs,
  callout,
  flip = false,
  photoSrc,
  photoAlt,
} = Astro.props;
---

<article
  class:list={[
    "grid gap-10 lg:gap-16 items-center md:grid-cols-2",
    flip && "md:[&>*:first-child]:order-2",
  ]}
>
  <!-- LEFT: media slot — real photograph when available, specimen card otherwise -->
  <aside
    class="relative aspect-[4/5] sm:aspect-[3/4] overflow-hidden bg-brand-black rounded-sm reveal"
  >
    {photoSrc ? (
      <Image
        src={photoSrc}
        alt={photoAlt ?? label}
        width={1200}
        height={1600}
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="absolute inset-0 flex flex-col">
        <div class="px-5 py-3 flex items-center justify-between border-b border-brand-bone/10">
          <span class="font-mono text-[10px] font-medium uppercase tracking-[0.22em] text-brand-bone-muted">
            ENV-{code}
          </span>
          <span class="font-mono text-[10px] font-medium uppercase tracking-[0.22em] text-brand-bone-muted">
            {label}
          </span>
        </div>

        <div class="flex-1 flex items-center justify-center text-brand-green">
          <LineArtIcon name={iconName} size={140} />
        </div>

        <div class="px-5 py-3 border-t border-brand-bone/10">
          <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-brand-bone-muted">
            Specimen rendering · photograph pending
          </div>
        </div>

        <span class="absolute top-2 left-2 w-3 h-3 border-l border-t border-brand-green/50" aria-hidden="true"></span>
        <span class="absolute top-2 right-2 w-3 h-3 border-r border-t border-brand-green/50" aria-hidden="true"></span>
        <span class="absolute bottom-2 left-2 w-3 h-3 border-l border-b border-brand-green/50" aria-hidden="true"></span>
        <span class="absolute bottom-2 right-2 w-3 h-3 border-r border-b border-brand-green/50" aria-hidden="true"></span>
      </div>
    )}
  </aside>

  <!-- RIGHT: content -->
  <div class="reveal">
    <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.22em] text-brand-green-deep">
      ENV-{code} · {label}
    </p>
    <h2 class="h2-section mt-3 text-brand-ink">{headline}</h2>

    {paragraphs.map((p) => (
      <p class="mt-5 text-brand-ink/75 leading-relaxed max-w-prose">{p}</p>
    ))}

    <dl class="mt-9 border-y border-brand-ink/10">
      {specs.map(([labelText, value]) => (
        <div class="grid grid-cols-[8.5rem_1fr] sm:grid-cols-[10rem_1fr] gap-x-4 py-3 border-b border-brand-ink/10 last:border-b-0">
          <dt class="font-mono text-[11px] font-medium uppercase tracking-[0.18em] text-brand-ink/55">
            {labelText}
          </dt>
          <dd class="font-mono text-[13px] text-brand-ink">{value}</dd>
        </div>
      ))}
    </dl>

    <p class="mt-9 font-serif italic text-lg leading-relaxed text-brand-ink/90 max-w-[44ch]">
      &ldquo;{callout}&rdquo;
    </p>
  </div>
</article>
