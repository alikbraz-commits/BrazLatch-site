---
/**
 * Engineering-line icons for application environments.
 * 24x24 viewBox, hairline strokes, currentColor — drop into any text color.
 */
type IconName =
  | "stalls"
  | "fences"
  | "trailers"
  | "backyards"
  | "warehouse"
  | "farms";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 28, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.25"
  stroke-linecap="square"
  stroke-linejoin="miter"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  {name === "stalls" && (
    <>
      <rect x="4" y="3" width="16" height="19" />
      <line x1="4" y1="12.5" x2="20" y2="12.5" />
      <line x1="13" y1="16.75" x2="18" y2="16.75" />
      <circle cx="17.25" cy="8.25" r="0.6" fill="currentColor" stroke="none" />
    </>
  )}

  {name === "fences" && (
    <>
      <line x1="3" y1="10" x2="21" y2="10" />
      <line x1="3" y1="16" x2="21" y2="16" />
      <line x1="5" y1="6" x2="5" y2="20" />
      <line x1="10" y1="6" x2="10" y2="20" />
      <line x1="14" y1="6" x2="14" y2="20" />
      <line x1="19" y1="6" x2="19" y2="20" />
    </>
  )}

  {name === "trailers" && (
    <>
      <rect x="5" y="7" width="15" height="7" />
      <line x1="5" y1="14" x2="2.5" y2="16.5" />
      <line x1="2.5" y1="16.5" x2="4.5" y2="16.5" />
      <circle cx="9" cy="18" r="2" />
      <circle cx="16" cy="18" r="2" />
    </>
  )}

  {name === "backyards" && (
    <>
      <polyline points="4,11 12,4 20,11" />
      <rect x="4" y="11" width="16" height="10" />
      <rect x="10.5" y="14" width="3" height="7" />
    </>
  )}

  {name === "warehouse" && (
    <>
      <rect x="3" y="6" width="18" height="15" />
      <rect x="8" y="11" width="8" height="10" />
      <line x1="8" y1="13.5" x2="16" y2="13.5" />
      <line x1="8" y1="16" x2="16" y2="16" />
      <line x1="8" y1="18.5" x2="16" y2="18.5" />
    </>
  )}

  {name === "farms" && (
    <>
      <polyline points="3,10 12,4 21,10" />
      <rect x="3" y="10" width="18" height="11" />
      <rect x="8" y="14" width="8" height="7" />
      <line x1="12" y1="14" x2="12" y2="21" />
    </>
  )}
</svg>
