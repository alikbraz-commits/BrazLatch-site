---
const links = [
  { href: "/how-it-works", label: "How it works" },
  { href: "/applications", label: "Applications" },
  { href: "/partner", label: "Partner" },
  { href: "/about", label: "About" },
  { href: "/buy", label: "Buy" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  id="siteHeader"
  class="sticky top-0 z-50 backdrop-blur transition-colors bg-brand-black/80 border-b border-white/5"
>
  <div class="container-page flex items-center justify-between h-16 sm:h-20">
    <a href="/" class="flex items-center gap-3" aria-label="BrazLatch home">
      <img src="/logo-mark-light.svg" alt="braz innovation" width="130" height="70" loading="eager" />
    </a>

    <button
      id="navToggle"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded border border-white/10"
      aria-expanded="false"
      aria-controls="navList"
      type="button"
    >
      <span class="sr-only">Open menu</span>
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>

    <nav id="navList" class="hidden md:flex items-center gap-1" aria-label="Primary">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-4 py-2 text-sm font-medium tracking-wide hover:text-brand-green",
            path === link.href ? "text-brand-green" : "text-brand-white/85",
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="ml-3 btn btn-primary text-xs">Contact</a>
    </nav>
  </div>

  <!-- Mobile drawer -->
  <div id="mobileMenu" class="hidden md:hidden border-t border-white/5 bg-brand-black">
    <nav class="container-page py-4 flex flex-col" aria-label="Mobile">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "py-3 text-base font-medium border-b border-white/5",
            path === link.href ? "text-brand-green" : "text-brand-white/85",
          ]}
        >
          {link.label}
        </a>
      ))}
      <a href="/contact" class="mt-4 btn btn-primary">Contact</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("mobileMenu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>
