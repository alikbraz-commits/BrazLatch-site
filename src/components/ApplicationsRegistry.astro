---
import { getCollection } from "astro:content";
import LineArtIcon from "./LineArtIcon.astro";
import { getSiteContent, makeGetter } from "../lib/siteContent";

const apps = (await getCollection("applications")).sort(
  (a, b) => a.data.order - b.data.order,
);

const c   = await getSiteContent();
const get = makeGetter(c);

// Maps content-collection order (1–6) to the sheet key prefix app.01 … app.06
const orderKey = (order: number) => `app.${String(order).padStart(2, '0')}`;

// Hardcoded fallbacks — used when sheet has no entry for a key
const labelFallback: Record<string, string> = {
  stalls:    "Equestrian",
  fences:    "Livestock",
  trailers:  "Trailers",
  backyards: "Backyards",
  warehouse: "Logistic",
  farms:     "Farms",
};

const bodyFallback: Record<string, string> = {
  stalls:
    "Stable doors that horses repeatedly defeat. Trapped-pin sequence makes the latch indifferent to nuzzling, pawing, and lever-pulling.",
  fences:
    "Cattle, sheep, and goats with hours to test a closure. Heavy-duty steel, sequence-only release. The difference between a quiet night and a 3 AM call.",
  trailers:
    "Spring tension holds the bolt against road vibration. Returns to locked between every stop, without driver attention.",
  backyards:
    "Pool gates, garden gates, kennel runs. Opens for the adult hand, foreign to small paws and curious toddlers.",
  warehouse:
    "Warehouse gates and equipment enclosures. One latch across the facility, one part number on the shelf.",
  farms:
    "Every gate on the property standardised on a single mechanism. One spare on the shelf, one motion every worker already knows.",
};
---

<section class="section section-dark border-t border-white/5">
  <div class="container-page">
    <header class="max-w-2xl reveal">
      <p class="kicker">In service</p>
      <h2 class="h2-section mt-3">One patent. Six environments. Same bolt.</h2>
      <p class="lede mt-6">
        The mechanism is currently installed across six environments where unintended opening is unacceptable. The bolt is identical. The mounting, the finish, and the gate context change.
      </p>
    </header>

    <ul
      class="mt-14 border-y border-brand-bone/10 divide-y divide-brand-bone/10"
      role="list"
    >
      {apps.map((app) => {
        const ok  = orderKey(app.data.order);
        const icon = app.data.icon as string;
        const label = get(`${ok}.title`, labelFallback[icon] ?? app.data.title);
        const body  = get(`${ok}.desc`,  bodyFallback[icon]  ?? app.data.description);
        return (
          <li class="reveal">
            <a
              href="/applications"
              class="group grid gap-x-5 gap-y-1 py-6 sm:py-7
                     grid-cols-[2.25rem_1fr]
                     sm:grid-cols-[2.5rem_7.5rem_1fr]
                     sm:items-center
                     transition-colors hover:bg-brand-bone/[0.025]"
            >
              <span
                class="text-brand-green row-span-2 sm:row-span-1 self-start sm:self-center"
                aria-hidden="true"
              >
                <LineArtIcon name={icon as any} size={28} />
              </span>
              <span class="spec-label group-hover:text-brand-green transition-colors">
                {label}
              </span>
              <span class="text-[15px] text-brand-white/85 leading-relaxed col-start-2 sm:col-start-3">
                {body}
              </span>
            </a>
          </li>
        );
      })}
    </ul>

    <div class="mt-12 reveal">
      <a href="/applications" class="btn-spec">
        See each environment <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>
