---
interface Props {
  variant?: "light" | "dark";
}
const { variant = "light" } = Astro.props;
const palette =
  variant === "light"
    ? "border-brand-white/20 text-brand-white/80"
    : "border-brand-ink/15 text-brand-ink/70";
---
<span class:list={["inline-flex items-center gap-2 rounded-full border px-3 py-1 text-[11px] font-mono uppercase tracking-widest", palette]}>
  <span class="inline-block w-1.5 h-1.5 rounded-full bg-brand-green" aria-hidden="true"></span>
  US Patent 10,934,749 · Protected in 7 markets
</span>
