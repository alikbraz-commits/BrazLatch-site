---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}

const { title, description, canonical, ogImage = "/og-default.jpg" } = Astro.props;
const siteUrl = "https://brazlatch.com";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Alik Alexander Braz" />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#0E0D0B" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="BrazLatch" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOgImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Fonts: IBM Plex Sans (industrial), JetBrains Mono (technical), Newsreader (editorial, restricted use) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Newsreader:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data: Organization + Product + WebSite -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          name: "Braz Innovation",
          alternateName: "BrazLatch",
          url: `${siteUrl}/`,
          logo: `${siteUrl}/favicon.svg`,
          founder: {
            "@type": "Person",
            name: "Alik Alexander Braz",
            jobTitle: "Founder and Inventor",
          },
          address: {
            "@type": "PostalAddress",
            addressLocality: "Mikhmoret",
            addressCountry: "IL",
          },
          contactPoint: {
            "@type": "ContactPoint",
            contactType: "licensing and distribution enquiries",
            email: "alik@brazlatch.com",
            areaServed: ["US", "CA", "AU", "NZ", "GB", "EU", "IN"],
          },
        },
        {
          "@type": "Product",
          name: "BrazLatch",
          description:
            "Patent-protected self-resetting triple-action sliding bolt latch. Animal-resistant, vibration-resistant, one-handed human operation.",
          brand: { "@id": `${siteUrl}/#organization` },
          manufacturer: { "@id": `${siteUrl}/#organization` },
          image: fullOgImage,
          category: "Hardware / Gate latches",
          url: `${siteUrl}/`,
          additionalProperty: {
            "@type": "PropertyValue",
            name: "Patent",
            value: "US10934749B2",
          },
        },
        {
          "@type": "WebSite",
          url: `${siteUrl}/`,
          name: "BrazLatch",
          publisher: { "@id": `${siteUrl}/#organization` },
          inLanguage: "en",
        },
      ],
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Reveal-on-scroll observer. No-op when no .reveal elements exist (Phase 1).
         Phase 2 components opt in by adding class="reveal" and optional style="--reveal-delay: 80ms". -->
    <script is:inline>
      (function () {
        if (typeof IntersectionObserver === "undefined") return;
        var els = document.querySelectorAll(".reveal");
        if (els.length === 0) return;
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        }, { rootMargin: "0px 0px -10% 0px", threshold: 0.05 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>
  </body>
</html>
