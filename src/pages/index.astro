---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import MechanismFilmstrip from "../components/MechanismFilmstrip.astro";
import ApplicationsRegistry from "../components/ApplicationsRegistry.astro";
import PatentMap from "../components/PatentMap.astro";
import AudienceRouter from "../components/AudienceRouter.astro";
import RetailerLogos from "../components/RetailerLogos.astro";
import LicensingStrip from "../components/LicensingStrip.astro";
import { getSiteContent, makeGetter } from "../lib/siteContent";

import horsePhoto from "../assets/photos/horse-rider-placeholder.jpg";

const page = await getEntry("pages", "home");
const c    = await getSiteContent();
const get  = makeGetter(c);

const storyImageUrl = get('home.story.image', '');
---
<BaseLayout title={page.data.title} description={page.data.description}>
  <Hero
    eyebrow={get('home.hero.eyebrow', 'Patent-protected · Triple-action mechanism')}
    title={get('home.hero.title', `The latch animals can't <span class="text-brand-green">figure out</span>.`)}
    subtitle={get('home.hero.subtitle', 'A self-resetting spring bolt latch that defeats interrupted opening attempts, while remaining easy to operate with one hand. Licensed and selling across America through National Hardware. Now seeking partners in six more markets.')}
    primaryCta={{ href: get('home.hero.cta1.href', '/partner'),      label: get('home.hero.cta1.label', 'Partner with us')     }}
    secondaryCta={{ href: get('home.hero.cta2.href', '/how-it-works'), label: get('home.hero.cta2.label', 'See how it works')  }}
    withPatentBadge={true}
    videoSrc={get('home.hero.video', '/videos/brazlatch-timeline.mp4')}
    posterSrc="/videos/brazlatch-timeline.mp4"
    variant="stack"
    animate={true}
  />

  <LicensingStrip />

  <!-- It started with a horse -->
  <section class="section section-cream">
    <div class="container-page grid gap-10 md:grid-cols-2 items-center">
      <div>
        <p class="kicker">The story</p>
        <h2 class="h2-section mt-3">{get('home.story.heading', 'It started with a horse.')}</h2>
        <p class="lede mt-6">
          {get('home.story.body', 'A stable owner. Horses who outsmarted every latch on the property. A workshop in Mikhmoret. A mechanism that resets itself the moment your hand leaves it. A US patent. A licensing deal with National Hardware. Today BrazLatch is on shelves across America, with six more markets opening next.')}
        </p>
        <a href={get('home.story.cta.href', '/about')} class="mt-8 inline-flex items-center gap-2 text-brand-green-deep font-semibold">
          {get('home.story.cta.label', 'Read the full story')} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="rounded-2xl overflow-hidden border border-brand-ink/10">
        {storyImageUrl
          ? <img src={storyImageUrl} alt={get('home.story.image.alt', 'Alik Braz at the family ranch in Mikhmoret')} class="w-full h-auto" width={960} height={640} loading="lazy" />
          : <Image src={horsePhoto} alt="Alik Braz at the family ranch in Mikhmoret" width={960} height={640} />
        }
      </div>
    </div>
  </section>

  <MechanismFilmstrip />

  <ApplicationsRegistry />

  <!-- Patent + retailers -->
  <section class="section section-dark">
    <div class="container-page grid gap-10 lg:grid-cols-2">
      <div>
        <p class="kicker">Proof and patent</p>
        <h2 class="h2-section mt-3">
          Patent-protected in 7 markets. Selling in the US since {get('home.patent.year', '[CONFIRM: launch year]')}.
        </h2>
        <p class="lede mt-6">
          BrazLatch's triple-action mechanism is protected by issued patents across seven markets. Manufactured at scale and on shelves at National Hardware, Amazon, and Lowe's across the United States.
        </p>
      </div>
      <div class="grid gap-6">
        <PatentMap />
        <RetailerLogos />
      </div>
    </div>
  </section>

  <AudienceRouter />
</BaseLayout>
