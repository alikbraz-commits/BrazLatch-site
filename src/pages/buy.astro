---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";

const retailers = [
  {
    name: "National Hardware",
    note: "The exclusive US licensee. Available at independent hardware retailers nationwide.",
    href: "https://www.nationalhardware.com/",
  },
  {
    name: "Amazon",
    note: "Shipped Prime across the United States.",
    href: "https://www.amazon.com/",
  },
  {
    name: "Lowe's",
    note: "In stores and online at Lowes.com.",
    href: "https://www.lowes.com/",
  },
];
---
<BaseLayout
  title="Buy BrazLatch — Available Across the United States"
  description="BrazLatch is sold across the United States through National Hardware, Amazon, and Lowe's."
>
  <Hero
    eyebrow="Where to buy"
    title="BrazLatch is available across the <span class='text-brand-green'>United States</span>."
    subtitle="Sold nationwide through National Hardware, Amazon, and Lowe's."
    variant="static"
  />

  <section class="section section-cream">
    <div class="container-page grid gap-6 md:grid-cols-3">
      {retailers.map((r) => (
        <a
          href={r.href}
          target="_blank"
          rel="noopener"
          class="rounded-2xl border border-brand-ink/15 bg-white p-8 transition hover:border-brand-green hover:shadow-lg"
        >
          <h3 class="text-2xl font-bold text-brand-ink">{r.name}</h3>
          <p class="mt-3 text-sm text-brand-ink/70">{r.note}</p>
          <p class="mt-6 text-brand-green-deep font-semibold inline-flex items-center gap-2">
            Visit <span aria-hidden="true">&rarr;</span>
          </p>
        </a>
      ))}
    </div>
  </section>

  <section class="section section-dark">
    <div class="container-page max-w-2xl text-center mx-auto">
      <p class="kicker">Outside the US?</p>
      <h2 class="h2-section mt-3">BrazLatch isn't yet available in your market &mdash; <span class="text-brand-green">but the opportunity is</span>.</h2>
      <p class="lede mt-6">If you're a distributor or licensee in Canada, Australia, the UK, the EU, India, or China, we want to hear from you.</p>
      <div class="mt-8 flex flex-wrap gap-4 justify-center">
        <a href="/partner" class="btn btn-primary">Partner with us</a>
        <a href="/contact" class="btn btn-ghost">Contact <span aria-hidden="true">&rarr;</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
