# Formspree endpoint — single endpoint with hidden `intent` field that
# routes server-side to licensing@ / distribution@ / hello@ at Formspree.
# Sign up at https://formspree.io, create a new form, paste its ID here.
# [CONFIRM: FORMSPREE_FORM_ID]
PUBLIC_FORMSPREE_ID=your_formspree_form_id

# Cloudflare Turnstile site key (free anti-spam widget)
# Create one at https://dash.cloudflare.com/?to=/:account/turnstile
# [CONFIRM: TURNSTILE_SITE_KEY]
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
